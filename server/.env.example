# Database connection (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/rikkahub
POSTGRES_URL=postgres://postgres:postgres@postgres:5432/rikkahub

# JWT secret for authentication (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change-me-to-a-secure-random-string

# Web access password
WEB_PASSWORD=rikkahub

# Server port
PORT=3001

# CORS origin (use comma-separated for multiple origins)
# For production, set to your frontend URL, e.g., https://your-frontend.vercel.app
CORS_ORIGIN=*

# Data directory for file storage
DATA_DIR=/app/data

# Vercel Blob token (optional, for file storage)
BLOB_READ_WRITE_TOKEN=