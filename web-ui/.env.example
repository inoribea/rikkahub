# Backend API Base URL (optional)
# When deploying frontend separately (e.g., on Vercel), set this to your backend server address.
# 
# Examples:
#   VITE_API_BASE_URL=http://192.168.1.100:8080        # Local development
#   VITE_API_BASE_URL=https://rikkahub-server.vercel.app  # Vercel deployment
#
# Priority: UI config (localStorage) > Environment variable > Default "/api"
# Users can override this in the UI settings dialog.
#
# For Vercel deployment:
# 1. Deploy server/ directory to Vercel first
# 2. Set this variable to your backend URL
# 3. Deploy web-ui/ directory to Vercel
VITE_API_BASE_URL=